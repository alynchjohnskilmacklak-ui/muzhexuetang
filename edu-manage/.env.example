# === Database ===
# DATABASE_URL 仅作兜底：所有分学部业务查询一律使用 getRequestPrisma()（从 session 获取正确的学部数据库）。
# 生产环境 DUAL_DB=true 时，DATABASE_URL 应指向其中一个真实库（建议 JUNIOR=muzhe_chuzhong），
# 使任何漏网的默认查询至少落在有效新库而非空旧库 edu_manage。
DATABASE_URL="postgresql://edu_admin:change-me@localhost:5432/muzhe_chuzhong"

# Dual Database (junior / senior division isolation)
DUAL_DB=true
DATABASE_URL_JUNIOR="postgresql://edu_admin:change-me@localhost:5432/muzhe_chuzhong?schema=public"
DATABASE_URL_SENIOR="postgresql://edu_admin:change-me@localhost:5432/muzhe_gaozhong?schema=public"

# === Auth ===
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_SECRET="replace-with-the-same-value-as-nextauth-secret"
NEXTAUTH_URL="https://你的域名"
AUTH_URL="https://你的域名"
AUTH_TRUST_HOST=true

# === First admin account ===
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=changeme123
# ADMIN_NAME=系统管理员
# Run once: npm run create-admin

# === Development / setup token ===
# SETUP_TOKEN=a-random-secret-string

# === AI providers ===
KIMI_API_KEY=""
KIMI_BASE_URL="https://api.moonshot.cn/v1"
KIMI_MODEL="moonshot-v1-8k"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
AI_TIMEOUT_MS=60000
AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_DAY=100

# === WxPusher ===
WXPUSHER_APP_TOKEN=""

# === Storage (local | aliyun-oss) ===
STORAGE_DRIVER=local
UPLOAD_DIR="public/uploads"
ALIYUN_OSS_REGION="oss-cn-hangzhou"
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ENDPOINT=""
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
ALIYUN_OSS_PUBLIC_BASE_URL=""
ALIYUN_OSS_PRIVATE_BUCKET=false

# === Redis (optional, memory fallback when absent) ===
# REDIS_URL=redis://localhost:6379
RATE_LIMIT_DRIVER=auto
SESSION_EVENT_DRIVER=auto

# === App ===
APP_TIMEZONE=Asia/Shanghai