DATABASE_URL="postgresql://edu_admin:change-me@localhost:5432/edu_manage"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_SECRET="replace-with-the-same-value-as-nextauth-secret"
NEXTAUTH_URL="http://your-server-ip:3000"
AUTH_URL="http://your-server-ip:3000"

# ── 首次部署：创建管理员 ──────────────────────────────
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=changeme123
# ADMIN_NAME=系统管理员
# 执行：npm run create-admin

# ── 开发/测试数据初始化（生产环境自动禁用）────────────
# SETUP_TOKEN=a-random-secret-string

# ── AI 接口速率限制 ────────────────────────────────────
# AI_RATE_LIMIT_PER_MINUTE=10
# AI_RATE_LIMIT_PER_DAY=100

# 阿里云 RDS 连接池建议（追加到 DATABASE_URL 末尾）
# DATABASE_URL="postgresql://user:pass@host:5432/db?connection_limit=10&pool_timeout=10&connect_timeout=10"
